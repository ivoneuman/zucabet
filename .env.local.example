# Copie este arquivo para .env.local e preencha com suas credenciais

# Supabase - obtenha em: https://supabase.com/dashboard → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave secreta para assinar os cookies de sessão (gere uma string aleatória longa)
# Exemplo: openssl rand -base64 32
SESSION_SECRET=troque-por-uma-string-secreta-longa-e-aleatoria

# Valor da aposta por jogo (em Kwanzas)
NEXT_PUBLIC_BET_AMOUNT=10000
